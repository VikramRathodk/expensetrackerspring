              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Returns array', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.status).to.be.true;",
                  "    pm.expect(json.data).to.be.an('array');",
                  "});",
                  "pm.test('All entries are active and not deleted', function () {",
                  "    pm.response.json().data.forEach(function (r) {",
                  "        pm.expect(r.isActive).to.be.true;",
                  "    });",
                  "});",
                  "pm.test('Each entry has required fields', function () {",
                  "    pm.response.json().data.forEach(function (r) {",
                  "        pm.expect(r).to.have.property('id');",
                  "        pm.expect(r).to.have.property('title');",
                  "        pm.expect(r).to.have.property('amount');",
                  "        pm.expect(r).to.have.property('frequency');",
                  "        pm.expect(r).to.have.property('nextDueDate');",
                  "        pm.expect(r).to.have.property('categoryId');",
                  "        pm.expect(r).to.have.property('categoryName');",
                  "    });",
                  "});"
                ],
