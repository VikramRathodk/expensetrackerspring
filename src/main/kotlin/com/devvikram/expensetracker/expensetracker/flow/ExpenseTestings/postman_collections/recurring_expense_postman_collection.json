            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/recurring-expenses",
              "host": ["{{base_url}}"],
              "path": ["api", "recurring-expenses"]
            },
            "description": "Returns all active, non-deleted recurring expenses for the authenticated user.\nInactive or soft-deleted entries are excluded.\nRepository method: `findByUserIdAndIsActiveTrueAndDeletedAtIsNull(userId)`"
          },
          "response": [
