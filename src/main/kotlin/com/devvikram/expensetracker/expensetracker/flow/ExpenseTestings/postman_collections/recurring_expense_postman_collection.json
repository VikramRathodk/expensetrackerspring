{
  "info": {
    "name": "Expense Tracker — Recurring Expense API",
    "_postman_id": "expense-tracker-recurring-expense-collection",
    "description": "Complete Postman collection for all Recurring Expense endpoints.\n\nSetup:\n1. Import this collection.\n2. Create an environment with variables: `base_url`, `token`, `recurring_id`.\n3. Run 'Login' from the Auth folder first — the test script auto-saves the token.\n4. All recurring expense requests use Bearer token auth inherited from the collection.\n\nFrequency values: DAILY | WEEKLY | MONTHLY | YEARLY",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8081",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    },
    {
      "key": "recurring_id",
      "value": "1",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth (prerequisite)",
      "item": [
        {
          "name": "Login — get token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.data && json.data.token) {",
                  "    pm.collectionVariables.set('token', json.data.token);",
                  "    console.log('Token saved:', json.data.token);",
                  "} else {",
                  "    console.warn('Login failed — no token in response');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "Login and auto-save JWT token to collection variable `token`.\nUpdate email/password to match a seeded user."
          },
          "response": [
            {
              "name": "200 — Login success",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"status\": true,\n  \"message\": \"Login successful\",\n  \"data\": {\n    \"token\": \"eyJhbGciOiJIUzI1NiJ9...\",\n    \"user\": {\n      \"id\": 1,\n      \"name\": \"Admin\",\n      \"email\": \"admin@example.com\",\n      \"roles\": [\"ADMIN\"]\n    }\n  }\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "Recurring Expense",
      "item": [
        {
          "name": "Create Recurring Expense — monthly, with endDate",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "pm.test('Response status is true', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.status).to.be.true;",
                  "    pm.expect(json.message).to.eql('Recurring expense created successfully');",
                  "});",
                  "pm.test('Recurring expense has correct fields', function () {",
                  "    var data = pm.response.json().data;",
                  "    pm.expect(data.title).to.eql('Netflix Subscription');",
                  "    pm.expect(data.amount).to.eql(499.0);",
                  "    pm.expect(data.frequency).to.eql('MONTHLY');",
                  "    pm.expect(data.isActive).to.be.true;",
                  "    pm.expect(data.nextDueDate).to.eql('2026-03-15');",
                  "    pm.expect(data.endDate).to.eql('2026-12-31');",
                  "    pm.expect(data).to.have.property('id');",
                  "    pm.expect(data).to.have.property('categoryId');",
                  "    pm.expect(data).to.have.property('categoryName');",
                  "    pm.expect(data).to.have.property('createdAt');",
                  "});",
                  "// Save id for subsequent requests",
                  "var id = pm.response.json().data.id;",
                  "if (id) pm.collectionVariables.set('recurring_id', id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Netflix Subscription\",\n  \"amount\": 499.0,\n  \"categoryId\": 1,\n  \"frequency\": \"MONTHLY\",\n  \"startDate\": \"2026-03-15\",\n  \"endDate\": \"2026-12-31\",\n  \"note\": \"Monthly streaming subscription\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/recurring-expenses",
              "host": ["{{base_url}}"],
              "path": ["api", "recurring-expenses"]
            },
            "description": "Creates a monthly recurring expense with a fixed end date.\n\n**frequency values:** DAILY | WEEKLY | MONTHLY | YEARLY\n**startDate:** first nextDueDate (date the scheduler will first process this entry)\n**endDate:** null = runs forever; set a date to auto-deactivate after that date\n**note:** optional free-text label"
          },
          "response": [
            {
              "name": "201 — Recurring expense created",
              "status": "Created",
              "code": 201,
              "body": "{\n  \"status\": true,\n  \"message\": \"Recurring expense created successfully\",\n  \"data\": {\n    \"id\": 1,\n    \"title\": \"Netflix Subscription\",\n    \"amount\": 499.0,\n    \"categoryId\": 1,\n    \"categoryName\": \"Entertainment\",\n    \"frequency\": \"MONTHLY\",\n    \"nextDueDate\": \"2026-03-15\",\n    \"endDate\": \"2026-12-31\",\n    \"isActive\": true,\n    \"note\": \"Monthly streaming subscription\",\n    \"createdAt\": \"2026-03-14T10:00:00\"\n  }\n}"
            },
            {
              "name": "404 — Category not found",
              "status": "Not Found",
              "code": 404,
              "body": "{\n  \"status\": false,\n  \"message\": \"Category with id 9999 not found\"\n}"
            },
            {
              "name": "401 — Unauthorized",
              "status": "Unauthorized",
              "code": 401,
              "body": "{\n  \"status\": false,\n  \"message\": \"Unauthorized\"\n}"
            }
          ]
        },
        {
          "name": "Create Recurring Expense — runs forever (no endDate)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "pm.test('endDate is null for open-ended recurring', function () {",
                  "    var data = pm.response.json().data;",
                  "    pm.expect(data.endDate).to.be.null;",
                  "    pm.expect(data.isActive).to.be.true;",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Gym Membership\",\n  \"amount\": 1200.0,\n  \"categoryId\": 2,\n  \"frequency\": \"MONTHLY\",\n  \"startDate\": \"2026-04-01\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/recurring-expenses",
              "host": ["{{base_url}}"],
              "path": ["api", "recurring-expenses"]
            },
            "description": "Creates a recurring expense with no end date — it runs until manually deleted or deactivated.\n`endDate` omitted → stored as `null`."
          },
          "response": [
            {
              "name": "201 — Open-ended recurring expense",
              "status": "Created",
              "code": 201,
              "body": "{\n  \"status\": true,\n  \"message\": \"Recurring expense created successfully\",\n  \"data\": {\n    \"id\": 2,\n    \"title\": \"Gym Membership\",\n    \"amount\": 1200.0,\n    \"categoryId\": 2,\n    \"categoryName\": \"Health\",\n    \"frequency\": \"MONTHLY\",\n    \"nextDueDate\": \"2026-04-01\",\n    \"endDate\": null,\n    \"isActive\": true,\n    \"note\": null,\n    \"createdAt\": \"2026-03-14T10:05:00\"\n  }\n}"
            }
          ]
        },
