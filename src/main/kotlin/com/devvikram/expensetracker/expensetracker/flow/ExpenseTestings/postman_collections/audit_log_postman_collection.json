        {
          "name": "Get Entity History — Expense",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Returns list (not paginated)', function () {",
                  "    pm.expect(pm.response.json().data).to.be.an('array');",
                  "});",
                  "pm.test('All logs refer to the same entity', function () {",
                  "    pm.response.json().data.forEach(function (log) {",
                  "        pm.expect(log.entityType).to.eql('Expense');",
                  "        pm.expect(log.entityId).to.eql(1);",
                  "    });",
                  "});",
                  "pm.test('Message is correct', function () {",
                  "    pm.expect(pm.response.json().message).to.eql('Entity audit history fetched successfully');",
                  "});"
                ],
                "type": "text/javascript"
              }
