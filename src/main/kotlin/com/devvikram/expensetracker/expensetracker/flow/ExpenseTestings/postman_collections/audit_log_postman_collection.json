{
  "info": {
    "name": "Expense Tracker — Audit Log API",
    "_postman_id": "expense-tracker-audit-log-collection",
    "description": "Complete Postman collection for all Audit Log endpoints.\n\nSetup:\n1. Import this collection.\n2. Create an environment with variables: `base_url`, `token`, `admin_token`, `super_admin_token`, `target_user_id`.\n3. Run 'Login' from the Auth folder first — the test script auto-saves the token.\n4. All audit log requests use Bearer token auth inherited from the collection.\n\nNote: Most endpoints require ADMIN or SUPER_ADMIN role.\nAuditAction values: EXPENSE_CREATED | EXPENSE_UPDATED | EXPENSE_DELETED | EXPENSE_AUTO_CREATED |\nBUDGET_CREATED | BUDGET_UPDATED | BUDGET_DELETED |\nRECURRING_EXPENSE_CREATED | RECURRING_EXPENSE_UPDATED | RECURRING_EXPENSE_DELETED | RECURRING_EXPENSE_PROCESSED |\nCATEGORY_CREATED | CATEGORY_UPDATED | CATEGORY_DELETED |\nUSER_REGISTERED | USER_LOGIN | ROLE_ASSIGNED",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8081",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    },
    {
      "key": "target_user_id",
      "value": "1",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth (prerequisite)",
      "item": [
        {
          "name": "Login as Admin — get token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.data && json.data.token) {",
                  "    pm.collectionVariables.set('token', json.data.token);",
                  "    console.log('Admin token saved:', json.data.token);",
                  "} else {",
                  "    console.warn('Login failed — no token in response');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "Login as an ADMIN user and auto-save JWT token to `{{token}}`.\nMost audit log endpoints require ADMIN or SUPER_ADMIN role.\nUpdate email/password to match a seeded admin user."
          },
          "response": [
            {
              "name": "200 — Login success",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"status\": true,\n  \"message\": \"Login successful\",\n  \"data\": {\n    \"token\": \"eyJhbGciOiJIUzI1NiJ9...\",\n    \"user\": {\n      \"id\": 1,\n      \"name\": \"Admin\",\n      \"email\": \"admin@example.com\",\n      \"roles\": [\"ADMIN\"]\n    }\n  }\n}"
            }
          ]
        },
        {
          "name": "Login as regular user — get token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.data && json.data.token) {",
                  "    pm.collectionVariables.set('token', json.data.token);",
                  "    console.log('User token saved:', json.data.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "Login as a regular USER to test the /me endpoint and 403 scenarios on admin-only endpoints."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Audit Logs",
      "item": [
        {
          "name": "Get All Logs — paginated (ADMIN)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Response status is true', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.status).to.be.true;",
                  "    pm.expect(json.message).to.eql('Audit logs fetched successfully');",
                  "});",
                  "pm.test('Data is a paginated response', function () {",
                  "    var data = pm.response.json().data;",
                  "    pm.expect(data).to.have.property('content');",
                  "    pm.expect(data).to.have.property('totalElements');",
                  "    pm.expect(data).to.have.property('totalPages');",
                  "    pm.expect(data.content).to.be.an('array');",
                  "});",
                  "pm.test('Each log has required fields', function () {",
                  "    var content = pm.response.json().data.content;",
                  "    if (content.length > 0) {",
                  "        var log = content[0];",
                  "        pm.expect(log).to.have.property('id');",
                  "        pm.expect(log).to.have.property('userId');",
                  "        pm.expect(log).to.have.property('action');",
                  "        pm.expect(log).to.have.property('entityType');",
                  "        pm.expect(log).to.have.property('createdAt');",
                  "    }",
                  "});",
                  "pm.test('Logs are ordered newest first', function () {",
                  "    var content = pm.response.json().data.content;",
                  "    if (content.length > 1) {",
                  "        var first = new Date(content[0].createdAt);",
                  "        var second = new Date(content[1].createdAt);",
                  "        pm.expect(first.getTime()).to.be.at.least(second.getTime());",
                  "    }",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/audit-logs?page=0&size=20",
              "host": ["{{base_url}}"],
              "path": ["api", "audit-logs"],
              "query": [
                { "key": "page", "value": "0" },
                { "key": "size", "value": "20" }
              ]
            },
            "description": "Returns all audit logs across all users, newest first.\nPaginated — use `page` and `size` query params.\nRequires ADMIN role."
          },
          "response": [
            {
              "name": "200 — Paginated audit logs",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"status\": true,\n  \"message\": \"Audit logs fetched successfully\",\n  \"data\": {\n    \"content\": [\n      {\n        \"id\": 10,\n        \"userId\": 1,\n        \"action\": \"EXPENSE_CREATED\",\n        \"entityType\": \"Expense\",\n        \"entityId\": 5,\n        \"oldValue\": null,\n        \"newValue\": \"{\\\"id\\\":5,\\\"title\\\":\\\"Lunch\\\",\\\"amount\\\":250.0}\",\n        \"ipAddress\": \"127.0.0.1\",\n        \"createdAt\": \"2026-03-14T12:00:00\"\n      }\n    ],\n    \"totalElements\": 1,\n    \"totalPages\": 1,\n    \"size\": 20,\n    \"number\": 0\n  }\n}"
            },
            {
              "name": "403 — Non-admin user",
              "status": "Forbidden",
              "code": 403,
              "body": "{\n  \"status\": false,\n  \"message\": \"Access Denied\"\n}"
            }
          ]
        },
        {
          "name": "Get All Logs — page 2",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Page number is 1', function () {",
                  "    pm.expect(pm.response.json().data.number).to.eql(1);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/audit-logs?page=1&size=10",
              "host": ["{{base_url}}"],
              "path": ["api", "audit-logs"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "size", "value": "10" }
              ]
            },
            "description": "Fetches the second page of audit logs with page size 10."
          },
          "response": []
