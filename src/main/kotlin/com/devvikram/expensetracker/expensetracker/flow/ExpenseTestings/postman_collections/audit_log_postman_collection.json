                  "    var tokenPayload = JSON.parse(atob(pm.collectionVariables.get('token').split('.')[1]));",
                  "    content.forEach(function (log) {",
                  "        pm.expect(log.userId).to.be.a('number');",
                  "    });",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
